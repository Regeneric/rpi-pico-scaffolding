{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "(ARM) [DEBUG] Configure",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "arm-debug"],
      "problemMatcher": []
    },
    {
      "label": "(ARM) [DEBUG] Build",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "arm-debug"],
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "(ARM) [DEBUG] Configure + Build",
      "dependsOrder": "sequence",
      "dependsOn": [
        "(ARM) [DEBUG] Configure",
        "(ARM) [DEBUG] Build"
      ],
      "problemMatcher": []
    },

    {
      "label": "(ARM) [RELEASE] Configure",
