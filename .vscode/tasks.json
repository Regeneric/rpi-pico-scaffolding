    {
      "label": "(ARM) [DEBUG] Flash RP2350 via OpenOCD",
      "type": "shell",
      "command": "openocd",
      "args": [
        "-s", "tcl",
        "-f", "interface/cmsis-dap.cfg",
        "-f", "target/rp2350.cfg",
        "-c", "adapter speed 3000",
        "-c", "program ${config:armDebugBuildDir}/src/${config:projectName}.elf verify reset exit"
      ],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "(RISC-V) [DEBUG] Flash RP2350 via OpenOCD",
      "type": "shell",
      "command": "openocd",
      "args": [
        "-s", "tcl",
        "-f", "interface/cmsis-dap.cfg",
        "-f", "target/rp2350-riscv.cfg",
        "-c", "adapter speed 3000",
        "-c", "program ${config:riscvDebugBuildDir}/src/${config:projectName}.elf verify reset exit"
      ],
      "problemMatcher": [],
