{
  "projectName": "PICO_RTOS",
  "buildPreset": "arm-debug",
  "armDebugBuildDir": "${workspaceFolder}/build/arm/debug",
  "riscvDebugBuildDir": "${workspaceFolder}/build/riscv/debug",
  
  "cmake.useCMakePresets": "always",
  "cmake.configureOnOpen": false,
  "files.associations": {
    "*.h": "c",
    "*.c": "c",
    "*.hpp": "cpp",
    "*.cpp": "cpp"
  },
  "C_Cpp.errorSquiggles": "enabled"
}